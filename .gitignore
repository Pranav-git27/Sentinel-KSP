# =============================================================
# Sentinel-KSP — Root .gitignore
# Full-stack monorepo: React frontend (client/) + Python
# serverless backend (functions/sentinel_api/)
# =============================================================


# -------------------------------------------------------------
# Explicitly tracked source directories
# -------------------------------------------------------------
# The top-level application source directories MUST always be
# tracked by Git. These negation rules defensively un-ignore
# them in case a broader pattern above ever matches them.
!functions/
!functions/**
!client/
!client/**


# -------------------------------------------------------------
# Python (Backend / functions/sentinel_api)
# -------------------------------------------------------------
# Virtual environments
.venv/
venv/
env/
ENV/

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*.pyc
*$py.class

# Distribution / packaging
*.egg
*.egg-info/
.eggs/
sdist/
wheels/
build/
dist/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
cover/
coverage.xml
*.cover
.pytest_cache/
.hypothesis/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py


# -------------------------------------------------------------
# Node.js / React (client/)
# -------------------------------------------------------------
# Dependencies
node_modules/
client/node_modules/
.pnp
.pnp.js
.pnp.cjs
.pnp.mjs

# Build outputs
dist/
build/
client/build/
.next/
out/
.vite/

# Testing / coverage
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# -------------------------------------------------------------
# Zoho Catalyst & local tool output
# -------------------------------------------------------------
.catalyst/
.catalystrc
catalyst-build/
*.catalyst.zip
graphify-out/
.graphify_analysis.json


# -------------------------------------------------------------
# Environment variables & secrets
# -------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.cert
secrets.json
credentials.json


# -------------------------------------------------------------
# Logs & temporary files
# -------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock


# -------------------------------------------------------------
# Editors / IDEs
# -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.history/


# -------------------------------------------------------------
# Operating Systems
# -------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
